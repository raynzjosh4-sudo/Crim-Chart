{
  "expo": {
    "name": "crimchart",
    "slug": "crimchart",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/appicon/appicon.png",
    "scheme": "crimchart",
    "userInterfaceStyle": "automatic",
    "backgroundColor": "#000000",
    "ios": {
      "icon": "./assets/appicon/appicon.png"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/appicon/appicon.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.crimchart.app",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "output": "single",
      "favicon": "./assets/appicon/appicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#000000",
          "image": "./assets/appicon/appicon.png",
          "imageWidth": 200
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-image",
      "expo-font",
      "expo-sqlite",
      "expo-video",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Crimchart to access your camera."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Crimchart to access your photos.",
          "savePhotosPermission": "Allow Crimchart to save photos.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      "@react-native-firebase/app",
      "@react-native-firebase/messaging",
      "./withNotifeeRepo.js",
      "@react-native-google-signin/google-signin",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "dfbc34f5-9353-4cdf-a993-15fd1fa60e26"
      }
    }
  }
}